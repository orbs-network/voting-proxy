{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/Strategy",
  "definitions": {
    "Strategy": {
      "title": "Strategy",
      "type": "object",
      "properties": {
        "sourceMethod": {
          "type": "string",
          "title": "Source method",
          "default": "source",
          "enum": ["source"]
        },
        "strategies": {
          "type": "array",
          "title": "Inner strategies",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "network": { "type": "string" },
              "params": { "type": "object" }
            },
            "required": ["name"],
            "additionalProperties": false
          }
        }
      },
      "required": ["strategies"],
      "additionalProperties": false
    }
  }
}
